NODE_ENV=development
PORT=3000
BOT_TOKEN=your-telegram-bot-token
BOT_USERNAME=your_bot_username
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=replace-with-long-random-secret
WEBHOOK_URL=https://bot.example.com/telegram/webhook
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baby_diary?schema=public
LOG_LEVEL=info

# Optional (used by scripts/smoke.ts)
SMOKE_BASE_URL=https://bot.example.com

# Dokploy production overrides:
# NODE_ENV=production
# DATABASE_URL=postgresql://postgres:<password>@postgres:5432/baby_diary?schema=public
